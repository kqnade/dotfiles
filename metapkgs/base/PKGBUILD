pkgname=base-env
pkgver=20260520
pkgrel=1
pkgdesc="My declarative base environment — OS-level deps only; dev tools live in mise"
arch=('any')
depends=(
  # Shell + system editor
  'zsh'
  'vim'

  # Version control & SSH
  'git'
  'git-lfs'
  'openssh'

  # Build toolchain for source builds (yaskkserv2 via cargo)
  'base-devel'
  'libyaml'

  # WSL → Windows 1Password SSH agent bridge (paired with scoop npiperelay)
  'socat'

  # Fonts + tools used by the font installer script
  'noto-fonts-cjk'
  'ttf-udev-gothic-nf'
  'fontconfig'
  'unzip'
)
# Notes:
# - chezmoi, mise, sheldon, starship, ghq, gh, glab, delta, gomi, neovim,
#   eza/fd/ripgrep/bat/fzf, lazygit, 1password-cli, and all language runtimes
#   (including rust for yaskkserv2) are managed by mise — see
#   dot_config/mise/config.toml. The bootstrap script installs chezmoi + mise
#   into ~/.local/bin before chezmoi apply runs.

# Always use the latest versions
pkgver() {
  date +%Y%m%d
}

package() {
  install -d "$pkgdir/usr/share/doc/$pkgname"
  echo "Applied: base-env" > "$pkgdir/usr/share/doc/$pkgname/README"
}
