pkgname=base-env
pkgver=20260520
pkgrel=1
pkgdesc="My declarative base environment — bootstrap-only deps; dev tools and bootstrap packages live in mise"
arch=('any')
depends=(
  # Build toolchain for source builds (yaskkserv2 via cargo). The shell,
  # editor, git, and ssh are now managed by mise [bootstrap.packages].
  'base-devel'
  'libyaml'

  # Fonts + tools used by the font installer script
  'noto-fonts-cjk'
  'ttf-udev-gothic-nf'
  'fontconfig'
  'unzip'
)
# Notes:
# - chezmoi, mise, zsh, vim, git, openssh, sheldon, starship, ghq, gh, glab,
#   delta, gomi, neovim, eza/fd/ripgrep/bat/fzf, lazygit, 1password-cli, and
#   all language runtimes (including rust for yaskkserv2) are managed by mise
#   — see dot_config/mise/config.toml. The bootstrap script installs chezmoi +
#   mise into ~/.local/bin before chezmoi apply runs.

# Always use the latest versions
pkgver() {
  date +%Y%m%d
}

package() {
  install -d "$pkgdir/usr/share/doc/$pkgname"
  echo "Applied: base-env" > "$pkgdir/usr/share/doc/$pkgname/README"
}
