pkgname=base-env
pkgver=20260513
pkgrel=1
pkgdesc="My declarative base environment"
arch=('any')
depends=(
  'mise'
  'libyaml'
  'ghq'
  'zsh'
  'chezmoi'
  'vim'
  'neovim'
  'sheldon'
  'git-delta'
  'git-lfs'
  'github-cli'
  'glab'
  'openssh'
  'rust'
)
# Note: 1Password CLI (`op`) lives in AUR (`1password-cli`) and is not
# installable via pacman alone. Install it manually with an AUR helper
# (e.g. `yay -S 1password-cli`) or install the 1Password Linux desktop
# package which bundles it. The supplementary installer in
# scripts/install-linux.sh also drops a static `op` binary into
# ~/.local/bin as a fallback.
# Note: UDEVGothic NF is installed by run_onchange_after_install-fonts.sh
# (downloaded from yuru7/udev-gothic releases) — keeps Arch + sudo path on
# pacman-only deps without requiring an AUR helper.

# Always use latest versions
pkgver() {
  date +%Y%m%d
}

package() {
  install -d "$pkgdir/usr/share/doc/$pkgname"
  echo "Applied: base-env" > "$pkgdir/usr/share/doc/$pkgname/README"
}
