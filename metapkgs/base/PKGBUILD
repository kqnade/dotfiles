pkgname=base-env
pkgver=20260505
pkgrel=1
pkgdesc="My declarative base environment"
arch=('any')
depends=(
  'mise'
  'libyaml'
  'ghq'
  'gnupg'
  'zsh'
  'tmux'
  'chezmoi'
  'vim'
  'neovim'
  'sheldon'
  'git-delta'
  'git-lfs'
  'github-cli'
  'glab'
  'openssh'
  'pinentry'
  'pass'
  'rust'
)
# Note: UDEVGothic NF is installed by run_onchange_after_install-fonts.sh
# (downloaded from yuru7/udev-gothic releases) — keeps Arch + sudo path on
# pacman-only deps without requiring an AUR helper.

# Always use latest versions
pkgver() {
  date +%Y%m%d
}

package() {
  install -d "$pkgdir/usr/share/doc/$pkgname"
  echo "Applied: base-env" > "$pkgdir/usr/share/doc/$pkgname/README"
}
