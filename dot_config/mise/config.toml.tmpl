[tools]
# Languages
node = "lts"
python = "3.12"
go = "latest"

{{- if ne .chezmoi.os "windows" }}
# ruby (ruby-build) and lua (vfox-lua) require source builds that fail on
# Windows without a Unix toolchain. Limit to non-Windows to keep the mise
# install path precompiled-only on Windows.
ruby = "latest"
lua = "latest"
{{- end }}

# CLI tools (all available as precompiled binaries on every supported OS)
eza = "latest"
fzf = "latest"
fd = "latest"
ripgrep = "latest"
bat = "latest"
starship = "latest"
bun = "latest"
deno = "latest"
tree-sitter = "latest"


"github:mtane0412/coscli" = { version = "latest", exe = "cos" }

[settings]
activate_aggressive = true

[settings.ruby]
compile = false
