# Global mise config — single source of truth for dev tools across all OSes.
# OS package managers (dnf / pacman / brew) only carry shell + git + build
# toolchain + fonts + system services. Everything else lives here.
#
# Intel Mac (darwin/amd64) は aqua レジストリが atuin/delta/sheldon/btop/fd の
# darwin/amd64 バイナリを持たないため、それらは Brewfile 側 (`Hardware::CPU.intel?`
# ガード) で補う。また、mise bootstrap packages の brew backend は arm64 macOS のみ
# 対応なので、brew: 系 bootstrap packages も Intel Mac では除外する。
{{- $isIntelMac := and (eq .chezmoi.os "darwin") (eq .chezmoi.arch "amd64") }}

[tools]

# ----------------------------------------------------------------------------
# Bootstrap / dotfiles management
# (chezmoi is also dropped into ~/.local/bin by scripts/install-linux.sh so it
#  can run before mise itself is installed; the mise-managed copy here keeps
#  it current after bootstrap.)
# ----------------------------------------------------------------------------
chezmoi = "latest"
{{- if not $isIntelMac }}
sheldon = "latest"
{{- end }}
starship = "latest"
ghq = "latest"
gh = "latest"
git-lfs = "latest"
{{- if not $isIntelMac }}
delta = "latest"
{{- end }}
difftastic = "latest"
gitleaks = "latest"

{{- $isWsl := and (eq .chezmoi.os "linux") (contains "microsoft" (.chezmoi.kernel.osrelease | default "" | lower)) -}}
{{- if not $isWsl }}
# WSL は Windows 側 scoop の op.exe を PATH 経由で叩くため Linux op CLI は不要。
"1password-cli" = "latest"
{{- end }}

# ----------------------------------------------------------------------------
# Modern CLI replacements
# ----------------------------------------------------------------------------
eza = "latest"
fzf = "latest"
{{- if not $isIntelMac }}
fd = "latest"
{{- end }}
ripgrep = "latest"
bat = "latest"
zoxide = "latest"
sd = "latest"
xh = "latest"
yq = "latest"
jq = "latest"
just = "latest"
{{- if eq .chezmoi.os "linux" }}
btop = "latest"
{{- end }}
{{- if not $isIntelMac }}
atuin = "latest"
{{- end }}
duf = "latest"
dust = "latest"
watchexec = "latest"
tree-sitter = "latest"

# gomi (trash CLI) and procs (process viewer) — explicit aqua backend.
"aqua:babarot/gomi" = "latest"
"aqua:dalance/procs" = "latest"

# coscli (Tencent Cloud Object Storage CLI) — custom github backend.
"github:mtane0412/coscli" = { version = "latest", exe = "cos" }

# pingu — ping, but cuter
"aqua:sheepla/pingu" = "latest"

{{- if eq .chezmoi.os "linux" }}
# yaskkserv2: macOS は delphinus/yaskkserv2 brew tap で入れる (Apple Silicon
# 対応バイナリが GitHub release に無いので)。Linux x86_64 は upstream release
# が出ているので mise github backend で取る。
"github:wachikun/yaskkserv2" = "latest"
{{- end }}

# ----------------------------------------------------------------------------
# Language runtimes + lint/format toolchains
# ----------------------------------------------------------------------------
go = "latest"
rust = "latest"
bun = "latest"
node = "lts"
deno = "latest"
uv = "latest"
clang = "latest"
"npm:nx" = "latest"
shellcheck = "latest"
shfmt = "latest"
taplo = "latest"
typos = "latest"

# ----------------------------------------------------------------------------
# LSP servers (shared by nvim + opencode)
# ----------------------------------------------------------------------------
# rust-analyzer can be installed via rustup after mise rust:
#   rustup component add rust-analyzer
rust-analyzer = "latest"
"aqua:LuaLS/lua-language-server" = "latest"
"go:golang.org/x/tools/gopls" = "latest"
"npm:typescript-language-server" = "latest"
"npm:vscode-langservers-extracted" = "latest"
"npm:yaml-language-server" = "latest"
"npm:bash-language-server" = "latest"
"npm:pyright" = "latest"
"npm:dockerfile-language-server-nodejs" = "latest"
"npm:@tailwindcss/language-server" = "latest"
"github:clojure-lsp/clojure-lsp" = "latest"
"github:fwcd/kotlin-language-server" = "latest"

# ----------------------------------------------------------------------------
# AI / agent CLIs
# ----------------------------------------------------------------------------
claude = "latest"
codex = "latest"
opencode = "latest"
"npm:ccusage" = "latest"
"npm:@moonshot-ai/kimi-code" = "latest"

# ----------------------------------------------------------------------------
# Editor (opt-out via .chezmoi.toml.tmpl: features.neovim)
# ----------------------------------------------------------------------------
{{- if .features.neovim }}
neovim = "latest"
{{- end }}

[settings]
activate_aggressive = true
npm.bun = true
experimental = {{ .features.mise_experimental }}
{{ if .features.mise_experimental }}
# Restrict bootstrap package managers so Linux uses only native package managers
# (dnf on Fedora, pacman on Arch, apt on Debian/Ubuntu). macOS uses Homebrew.
# Windows has no bootstrap package support in mise.
system_packages.managers = [
    {{ if eq .chezmoi.os "linux" -}}
    "{{ if eq .chezmoi.osRelease.id "fedora" }}dnf{{ else if eq .chezmoi.osRelease.id "arch" }}pacman{{ else }}apt{{ end }}"
    {{- else if eq .chezmoi.os "darwin" -}}
    "brew"
    {{- end }}
]

# ----------------------------------------------------------------------------
# Bootstrap packages (experimental) — machine-global bootstrap packages managed
# by `mise bootstrap packages install`. These replace the overlapping OS-manifest
# entries that were duplicated across Dnffile / Brewfile / PKGBUILD.
#
# Rules of thumb:
#   - Put shell / system editor / SSH / build toolchain here.
#   - Keep casks, fonts, yaskkserv2 tap, and Intel Mac fallbacks in Brewfile.
#     (mise bootstrap packages' brew backend only supports arm64 macOS.)
#   - Keep distro-specific groups (Arch base-devel) and fonts in PKGBUILD.
#   - Windows is unchanged (scoop backend is not supported by bootstrap packages).
# ----------------------------------------------------------------------------
[bootstrap.packages]

# Shell + system editor + SSH
"apt:zsh" = "latest"
"apt:vim" = "latest"
"apt:openssh-client" = "latest"
"dnf:zsh" = "latest"
"dnf:vim-enhanced" = "latest"
"dnf:openssh-clients" = "latest"
"pacman:zsh" = "latest"
"pacman:vim" = "latest"
"pacman:openssh" = "latest"
{{- if not $isIntelMac }}
"brew:zsh" = "latest"
"brew:vim" = "latest"
"brew:openssh" = "latest"
{{- end }}

# Build toolchain (yaskkserv2 cargo build needs a C compiler)
"apt:build-essential" = "latest"
"dnf:gcc" = "latest"
"dnf:gcc-c++" = "latest"
"dnf:make" = "latest"
# pacman: base-devel group stays in metapkgs/base/PKGBUILD
# brew: Xcode CLI tools provide the toolchain
{{- end }}
