# Global mise config — single source of truth for dev tools across all OSes.
# OS package managers (dnf / pacman / brew) only carry shell + git + build
# toolchain + fonts + system services. Everything else lives here.
#
# Intel Mac (darwin/amd64) は aqua レジストリが atuin/delta/sheldon/btop/fd の
# darwin/amd64 バイナリを持たないため、それらは Brewfile 側 (`Hardware::CPU.intel?`
# ガード) で補う。下の条件分岐で mise から除外する。
{{- $isIntelMac := and (eq .chezmoi.os "darwin") (eq .chezmoi.arch "amd64") }}

[tools]

# ----------------------------------------------------------------------------
# Bootstrap / dotfiles management
# (chezmoi is also dropped into ~/.local/bin by scripts/install-linux.sh so it
#  can run before mise itself is installed; the mise-managed copy here keeps
#  it current after bootstrap.)
# ----------------------------------------------------------------------------
chezmoi = "latest"
{{- if not $isIntelMac }}
sheldon = "latest"
{{- end }}
starship = "latest"
ghq = "latest"
gh = "latest"
git-lfs = "latest"
{{- if not $isIntelMac }}
delta = "latest"
{{- end }}
difftastic = "latest"
gitleaks = "latest"

{{- $isWsl := and (eq .chezmoi.os "linux") (contains "microsoft" (.chezmoi.kernel.osrelease | default "" | lower)) -}}
{{- if not $isWsl }}
# WSL は Windows 側 scoop の op.exe を PATH 経由で叩くため Linux op CLI は不要。
"1password-cli" = "latest"
{{- end }}

# ----------------------------------------------------------------------------
# Modern CLI replacements
# ----------------------------------------------------------------------------
eza = "latest"
fzf = "latest"
{{- if not $isIntelMac }}
fd = "latest"
{{- end }}
ripgrep = "latest"
bat = "latest"
zoxide = "latest"
sd = "latest"
xh = "latest"
yq = "latest"
jq = "latest"
just = "latest"
{{- if not $isIntelMac }}
atuin = "latest"
btop = "latest"
{{- end }}
duf = "latest"
dust = "latest"
watchexec = "latest"
tree-sitter = "latest"

# gomi (trash CLI) and procs (process viewer) — explicit aqua backend.
"aqua:babarot/gomi" = "latest"
"aqua:dalance/procs" = "latest"

# coscli (Tencent Cloud Object Storage CLI) — custom github backend.
"github:mtane0412/coscli" = { version = "latest", exe = "cos" }

# pingu — ping, but cuter
"aqua:sheepla/pingu" = "latest"

{{- if eq .chezmoi.os "linux" }}
# yaskkserv2: macOS は delphinus/yaskkserv2 brew tap で入れる (Apple Silicon
# 対応バイナリが GitHub release に無いので)。Linux x86_64 は upstream release
# が出ているので mise github backend で取る。
"github:wachikun/yaskkserv2" = "latest"
{{- end }}

# ----------------------------------------------------------------------------
# Language runtimes + lint/format toolchains
# ----------------------------------------------------------------------------
go = "latest"
rust = "latest"
bun = "latest"
deno = "latest"
uv = "latest"
clang = "latest"
shellcheck = "latest"
shfmt = "latest"
taplo = "latest"
typos = "latest"

# ----------------------------------------------------------------------------
# LSP servers (shared by nvim + opencode)
# ----------------------------------------------------------------------------
# rust-analyzer can be installed via rustup after mise rust:
#   rustup component add rust-analyzer
rust-analyzer = "latest"
"aqua:LuaLS/lua-language-server" = "latest"
"go:golang.org/x/tools/gopls" = "latest"
"npm:typescript-language-server" = "latest"
"npm:vscode-langservers-extracted" = "latest"
"npm:yaml-language-server" = "latest"
"npm:bash-language-server" = "latest"
"npm:pyright" = "latest"
"npm:dockerfile-language-server-nodejs" = "latest"
"npm:@tailwindcss/language-server" = "latest"
"github:clojure-lsp/clojure-lsp" = "latest"
"github:fwcd/kotlin-language-server" = "latest"

# ----------------------------------------------------------------------------
# AI / agent CLIs
# ----------------------------------------------------------------------------
claude = "latest"
codex = "latest"
opencode = "latest"

# ----------------------------------------------------------------------------
# Editor (opt-out via .chezmoi.toml.tmpl: features.neovim)
# ----------------------------------------------------------------------------
{{- if .features.neovim }}
neovim = "latest"
{{- end }}

[settings]
activate_aggressive = true
