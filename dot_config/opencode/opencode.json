{
  "$schema": "https://opencode.ai/config.json",

  "model": "opencode-go/kimi-k2.6",

  "autoupdate": true,

  "permission": {
    "edit": "ask",
    "bash": "ask"
  },

  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },

  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      "build/**",
      ".git/**",
      ".next/**",
      "target/**",
      "coverage/**"
    ]
  },

  "instructions": [
    "AGENTS.md",
    ".cursor/rules/*.md"
  ]
}
