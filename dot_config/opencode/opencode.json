{
  "$schema": "https://opencode.ai/config.json",

  "model": "kimi/KimiK2.7Code",

  "autoupdate": true,

  "permission": {
    "read": {
      "*": "allow",
      ".env": "deny",
      ".env.*": "deny",
      "**/.env": "deny",
      "**/.env.*": "deny",
      "secrets/**": "deny",
      "**/secrets/**": "deny",
      "*.pem": "deny",
      "**/*.pem": "deny",
      "*.key": "deny",
      "**/*.key": "deny"
    },
    "edit": {
      "*": "allow",
      ".env": "deny",
      ".env.*": "deny",
      "**/.env": "deny",
      "**/.env.*": "deny",
      "secrets/**": "deny",
      "**/secrets/**": "deny",
      "*.pem": "deny",
      "**/*.pem": "deny",
      "*.key": "deny",
      "**/*.key": "deny"
    },
    "bash": {
      "*": "ask",
      "git *": "allow",
      "cargo *": "allow",
      "go *": "allow",
      "zig *": "allow",
      "npm *": "allow",
      "rm -rf": "deny",
      "rm -rf *": "deny",
      "git push --force": "deny",
      "git push --force *": "deny",
      "git push -f": "deny",
      "git push -f *": "deny"
    }
  },

  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },

  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      "build/**",
      ".git/**",
      ".next/**",
      "target/**",
      "coverage/**"
    ]
  },

  "instructions": [
    "AGENTS.md",
    ".cursor/rules/*.md"
  ],

  "lsp": {
    "bash": {
      "command": ["bash-language-server", "start"],
      "extensions": [".sh", ".bash", ".zsh"]
    },
    "clojure": {
      "command": ["clojure-lsp"],
      "extensions": [".clj", ".cljs", ".cljc", ".edn"]
    },
    "cpp": {
      "command": ["clangd"],
      "extensions": [".c", ".cpp", ".cc", ".cxx", ".h", ".hpp", ".hxx"]
    },
    "csharp": {
      "command": ["omnisharp"],
      "extensions": [".cs", ".csx"]
    },
    "css": {
      "command": ["vscode-css-language-server", "--stdio"],
      "extensions": [".css", ".scss", ".less"]
    },
    "dockerfile": {
      "command": ["docker-langserver", "--stdio"],
      "extensions": [".dockerfile"]
    },
    "go": {
      "command": ["gopls"],
      "extensions": [".go"]
    },
    "html": {
      "command": ["vscode-html-language-server", "--stdio"],
      "extensions": [".html", ".htm"]
    },
    "java": {
      "command": ["jdtls"],
      "extensions": [".java"]
    },
    "javascript": {
      "command": ["typescript-language-server", "--stdio"],
      "extensions": [".js", ".jsx", ".mjs", ".cjs"]
    },
    "json": {
      "command": ["vscode-json-language-server", "--stdio"],
      "extensions": [".json"]
    },
    "jsonc": {
      "command": ["vscode-json-language-server", "--stdio"],
      "extensions": [".jsonc"]
    },
    "kotlin": {
      "command": ["kotlin-language-server"],
      "extensions": [".kt", ".kts"]
    },
    "lua": {
      "command": ["lua-language-server"],
      "extensions": [".lua"]
    },
    "powershell": {
      "command": ["powershell-editor-services", "--stdio"],
      "extensions": [".ps1", ".psm1", ".psd1"]
    },
    "python": {
      "command": ["pyright-langserver", "--stdio"],
      "extensions": [".py", ".pyi"]
    },
    "ruby": {
      "command": ["ruby-lsp"],
      "extensions": [".rb", ".rake", ".gemspec"]
    },
    "rust": {
      "command": ["rust-analyzer"],
      "extensions": [".rs"]
    },
    "tailwindcss": {
      "command": ["tailwindcss-language-server", "--stdio"],
      "extensions": [".css", ".html", ".jsx", ".tsx", ".vue"]
    },
    "typescript": {
      "command": ["typescript-language-server", "--stdio"],
      "extensions": [".ts", ".tsx", ".mts", ".cts"]
    },
    "yaml": {
      "command": ["yaml-language-server", "--stdio"],
      "extensions": [".yaml", ".yml"]
    }
  }
}
