{
  "$schema": "https://raw.githubusercontent.com/manaflow-ai/cmux/main/web/data/cmux.schema.json",
  "schemaVersion": 1,

  "app": {
    "appearance": "dark",
    "workspaceInheritWorkingDirectory": true,
    "openSupportedFilesInCmux": true,
    "openMarkdownInCmuxViewer": true,
    "sendAnonymousTelemetry": false
  },

  "terminal": {
    "showScrollBar": false,
    "autoResumeAgentSessions": false
  },

  "notifications": {
    "agentPermissionPrompt": true,
    "agentTurnComplete": "whenIdle",
    "agentIdleReminder": true
  },

  "automation": {
    "suppressSubagentNotifications": true
  },

  "actions": {
    "ghq-worktree": {
      "type": "workspaceCommand",
      "title": "New Git Worktree",
      "subtitle": "Create a branch worktree with wt",
      "commandName": "New Git Worktree",
      "icon": { "type": "symbol", "name": "arrow.triangle.branch" }
    },
    "home-workspace": {
      "type": "workspace",
      "title": "Home Workspace",
      "subtitle": "Open an ungrouped shell in the home directory",
      "newWorkspaceMenu": false,
      "icon": { "type": "symbol", "name": "house.fill" },
      "workspace": {
        "name": "Home",
        "cwd": "~",
        "layout": {
          "pane": {
            "surfaces": [
              { "type": "terminal", "name": "Home", "focus": true }
            ]
          }
        }
      }
    }
  },

  "ui": {
    "newWorkspace": {
      "action": "cmux.config.command.New%20Git%20Worktree",
      "contextMenu": [
        { "action": "ghq-worktree", "title": "New Git Worktree" },
        { "type": "separator" },
        { "action": "cmux.newTerminal", "title": "New Terminal" },
        { "action": "cmux.newBrowser", "title": "New Browser" }
      ]
    }
  },

  "workspaceGroups": {
    "newWorkspacePlacement": "afterCurrent",
    "byCwd": {
      "~/repos": {
        "color": "#1565C0",
        "icon": "folder.badge.gearshape",
        "newWorkspacePlacement": "afterCurrent",
        "contextMenu": [
          { "action": "ghq-worktree", "title": "New Git Worktree" },
          { "action": "home-workspace", "title": "Home Workspace" },
          { "type": "separator" },
          { "action": "cmux.newTerminal", "title": "New Terminal" },
          { "action": "cmux.newBrowser", "title": "New Browser" }
        ]
      }
    }
  },

  "commands": [
    {
      "name": "New Git Worktree",
      "description": "Prompt for a branch and create its worktree with wt",
      "keywords": ["git", "ghq", "branch", "issue", "worktree"],
      "workspace": {
        "name": "New Worktree",
        "cwd": ".",
        "layout": {
          "pane": {
            "surfaces": [
              {
                "type": "terminal",
                "name": "Worktree",
                "command": "$HOME/.local/bin/cmux-worktree",
                "focus": true
              }
            ]
          }
        }
      }
    }
  ],

  "browser": {
    "hostsToOpenInEmbeddedBrowser": ["localhost", "127.0.0.1", "*.localhost"]
  }
}
