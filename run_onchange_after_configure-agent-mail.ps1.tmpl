$ErrorActionPreference = "Stop"

$missing = @("claude", "codex") | Where-Object {
    -not (Get-Command $_ -ErrorAction SilentlyContinue)
}
if ($missing.Count -gt 0) {
    throw "missing agent CLIs: $($missing -join ', '); run chezmoi apply again after mise install"
}

& claude mcp remove --scope user agent-mail 2>$null
& codex mcp remove agent-mail 2>$null

& claude mcp get mcp-agent-mail *> $null
if ($LASTEXITCODE -ne 0) {
    throw "Claude's mcp-agent-mail HTTP entry is missing or unhealthy; rerun chezmoi apply"
}

& codex mcp get mcp_agent_mail *> $null
if ($LASTEXITCODE -ne 0) {
    throw "Codex's mcp_agent_mail HTTP entry is missing; rerun chezmoi apply"
}
