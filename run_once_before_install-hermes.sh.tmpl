{{- if ne .chezmoi.os "windows" -}}
#!/usr/bin/env bash
set -euo pipefail

# Hermes maintains its own checkout, virtual environment, and updater under
# ~/.hermes. Use the upstream installer instead of duplicating that lifecycle
# in mise or chezmoi. User configuration and credentials are preserved.
if ! command -v hermes >/dev/null 2>&1; then
  curl -fsSL https://hermes-agent.nousresearch.com/install.sh | bash
fi
{{- end }}
