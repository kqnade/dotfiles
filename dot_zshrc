export LANG="en_US.UTF-8"
export EDITOR="vim"
export VISUAL="vim"

# Homebrew (macOS only)
if [[ "$(uname -s)" == "Darwin" ]]; then
  if [[ -x /opt/homebrew/bin/brew ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
  elif [[ -x /usr/local/bin/brew ]]; then
    eval "$(/usr/local/bin/brew shellenv)"
  fi
fi

export GPG_TTY=$(tty)
# pixi (non-sudo Linux package manager) bin dir is prepended when present.
export PATH="$HOME/.pixi/bin:$HOME/.local/bin:$HOME/.bun/bin:$PATH"

# sideapt: non-root apt wrapper (Debian/Ubuntu hosts without sudo).
# Prepends ~/.sideapt/usr to PATH/LD_LIBRARY_PATH/MANPATH/PKG_CONFIG_PATH.
command -v sideapt >/dev/null 2>&1 && eval "$(sideapt env)"

if command -v gpgconf &>/dev/null; then
  export SSH_AUTH_SOCK=$(gpgconf --list-dirs agent-ssh-socket)
  gpg-connect-agent updatestartuptty /bye > /dev/null 2>&1
fi

# zsh-completions ships extra completion functions; they must be added to
# fpath BEFORE compinit. sheldon clones the repo for us; we just point fpath
# at its src/ directory here.
typeset -aU fpath
_sheldon_data="${XDG_DATA_HOME:-$HOME/.local/share}/sheldon"
[[ -d $_sheldon_data/repos/github.com/zsh-users/zsh-completions/src ]] \
  && fpath=("$_sheldon_data/repos/github.com/zsh-users/zsh-completions/src" $fpath)
unset _sheldon_data

autoload -Uz compinit
compinit

eval "$(mise activate zsh)"
# mise's go plugin force-exports GOBIN=<mise_install_dir>/bin and the upstream
# has no flag to disable it. That env var leaks into Mason (nvim) and breaks
# its sandboxed `go install` of gopls/gofumpt/goimports. Drop it here so
# `go install` falls back to GOPATH/bin (or whatever the caller sets).
unset GOBIN
eval "$(sheldon source)"
eval "$(starship init zsh)"

HISTFILE="$HOME/.zsh_history"
HISTSIZE=100000
SAVEHIST=100000

setopt share_history           # 履歴を他セッションと共有
setopt hist_ignore_all_dups    # 重複を記録しない
setopt hist_reduce_blanks      # 余白を詰める
setopt auto_cd                 # ディレクトリ名のみで移動
setopt auto_pushd              # cd 時にスタックに積む
setopt pushd_ignore_dups       # スタックの重複防止

bindkey -e                     # Emacs キーバインド
bindkey '^[[A' history-substring-search-up
bindkey '^[[B' history-substring-search-down

zstyle ':fzf-tab:*' fzf-flags --height=40% --layout=reverse --border
zstyle ':fzf-tab:complete: cd:*' fzf-preview 'ls -la $realpath'

for f in ~/.config/zsh/**/*.zsh(N); do source $f; done
