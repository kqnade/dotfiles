# ~/.bashrc — managed by chezmoi.
# Mirrors dot_zshrc as closely as bash supports.

# Skip non-interactive shells (scp, rsync, etc.).
[[ $- != *i* ]] && return

export LANG="en_US.UTF-8"
export EDITOR="vim"
export VISUAL="vim"

export GPG_TTY=$(tty)
export PATH="$HOME/.local/bin:$HOME/.bun/bin:$PATH"

# 1Password SSH agent (native socket on macOS / Linux desktop). WSL uses
# ssh.exe via git's core.sshCommand instead — see dot_gitconfig.tmpl.
# macOS launchd presets SSH_AUTH_SOCK to its own agent, so we override
# unconditionally when the 1Password socket exists.
case "$OSTYPE" in
  darwin*) _op_sock="$HOME/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock" ;;
  linux*)  _op_sock="$HOME/.1password/agent.sock" ;;
esac
[[ -n "${_op_sock-}" && -S "$_op_sock" ]] && export SSH_AUTH_SOCK="$_op_sock"
unset _op_sock

# 1Password CLI plugin aliases — generated by `op plugin init <cli>`
# Skip in WSL: 1Password shell plugins are not supported there.
if [[ "$(uname -r)" != *microsoft* && "$(uname -r)" != *WSL* ]]; then
  [[ -f "$HOME/.config/op/plugins.sh" ]] && source "$HOME/.config/op/plugins.sh"
fi

# ---------------------------------------------------------------------------
# bash options
# ---------------------------------------------------------------------------
HISTFILE="$HOME/.bash_history"
HISTSIZE=100000
HISTFILESIZE=100000
HISTCONTROL=ignoreboth:erasedups

shopt -s histappend
shopt -s checkwinsize
shopt -s autocd 2>/dev/null
shopt -s globstar 2>/dev/null

# bash-completion (varies by distro; quietly skip if not present)
for f in /usr/share/bash-completion/bash_completion /etc/bash_completion; do
  [[ -r "$f" ]] && { source "$f"; break; }
done

# ---------------------------------------------------------------------------
# Tooling activation
# ---------------------------------------------------------------------------
if command -v mise &>/dev/null; then
  eval "$(mise activate bash)"
fi

if command -v starship &>/dev/null; then
  eval "$(starship init bash)"
fi

if command -v zoxide &>/dev/null; then
  eval "$(zoxide init bash --cmd cd)"
fi

if command -v atuin &>/dev/null; then
  eval "$(atuin init bash)"
fi

if command -v fzf &>/dev/null; then
  # bash 5.1+ supports `fzf --bash`; older fzf releases ship a separate script.
  if fzf --bash >/dev/null 2>&1; then
    eval "$(fzf --bash)"
  fi
fi

# ---------------------------------------------------------------------------
# Shared aliases (bash-compatible subset of dot_config/zsh/aliases.zsh)
# zsh-only function files under dot_config/zsh/functions/ are NOT sourced —
# they use zsh idioms (zsh-style read -q, ${@[-1]}) that won't run in bash.
# ---------------------------------------------------------------------------
if [[ -r "$HOME/.config/zsh/aliases.zsh" ]]; then
  source "$HOME/.config/zsh/aliases.zsh"
fi
