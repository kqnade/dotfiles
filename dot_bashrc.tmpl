# ~/.bashrc — managed by chezmoi.
# Mirrors dot_zshrc as closely as bash supports. On Windows this is read by
# MSYS2's bash when MSYS2 is configured to use %USERPROFILE% as $HOME (see
# docs/setup-windows.md).

# Skip non-interactive shells (scp, rsync, etc.).
[[ $- != *i* ]] && return

# ---------------------------------------------------------------------------
# MSYS2 bootstrap
# Non-login shells skip /etc/profile, leaving /usr/bin out of PATH and the
# inherited Windows PATH stuck in `;`-separated form. Source /etc/profile
# explicitly so coreutils (uname, ls, ...) resolve and PATH gets converted
# to MSYS2's `:`-separated `/c/...` form. $MSYSTEM is set by MSYS2 itself.
# Windows-side tooling (mise, scoop shims) is intentionally NOT activated
# here — they are Windows binaries that emit Windows-style PATH, which
# clobbers the MSYS2 PATH and breaks command lookup. Use them from
# PowerShell instead.
# ---------------------------------------------------------------------------
if [[ -n "$MSYSTEM" ]]; then
  if [[ -r /etc/profile ]]; then
    source /etc/profile
  fi

  export LANG="en_US.UTF-8"
  export EDITOR="vim"
  export VISUAL="vim"

  HISTFILE="$HOME/.bash_history"
  HISTSIZE=100000
  HISTFILESIZE=100000
  HISTCONTROL=ignoreboth:erasedups
  shopt -s histappend checkwinsize
  shopt -s autocd globstar 2>/dev/null

  for f in /usr/share/bash-completion/bash_completion /etc/bash_completion; do
    [[ -r "$f" ]] && { source "$f"; break; }
  done

  if [[ -r "$HOME/.config/zsh/aliases.zsh" ]]; then
    source "$HOME/.config/zsh/aliases.zsh"
  fi

  return
fi

export LANG="en_US.UTF-8"
export EDITOR="vim"
export VISUAL="vim"

# ---------------------------------------------------------------------------
# Homebrew (macOS only) — non-sudo Linux uses pixi instead, see ~/.pixi/bin.
# ---------------------------------------------------------------------------
if [[ "$(uname -s)" == "Darwin" ]]; then
  if [[ -x /opt/homebrew/bin/brew ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
  elif [[ -x /usr/local/bin/brew ]]; then
    eval "$(/usr/local/bin/brew shellenv)"
  fi
fi

export GPG_TTY=$(tty)
export PATH="$HOME/.pixi/bin:$HOME/.local/bin:$HOME/.bun/bin:$PATH"

# sideapt: non-root apt wrapper (Debian/Ubuntu hosts without sudo).
# Prepends ~/.sideapt/usr to PATH/LD_LIBRARY_PATH/MANPATH/PKG_CONFIG_PATH.
command -v sideapt >/dev/null 2>&1 && eval "$(sideapt env)"

if command -v gpgconf &>/dev/null; then
  export SSH_AUTH_SOCK=$(gpgconf --list-dirs agent-ssh-socket)
  gpg-connect-agent updatestartuptty /bye > /dev/null 2>&1
fi

# ---------------------------------------------------------------------------
# bash options
# ---------------------------------------------------------------------------
HISTFILE="$HOME/.bash_history"
HISTSIZE=100000
HISTFILESIZE=100000
HISTCONTROL=ignoreboth:erasedups

shopt -s histappend
shopt -s checkwinsize
shopt -s autocd 2>/dev/null
shopt -s globstar 2>/dev/null

# bash-completion (varies by distro; quietly skip if not present)
for f in /usr/share/bash-completion/bash_completion /etc/bash_completion; do
  [[ -r "$f" ]] && { source "$f"; break; }
done

# ---------------------------------------------------------------------------
# Tooling activation
# ---------------------------------------------------------------------------
if command -v mise &>/dev/null; then
  eval "$(mise activate bash)"
  # mise's go plugin force-exports GOBIN=<mise_install_dir>/bin and the
  # upstream has no flag to disable it. That env var leaks into Mason (nvim)
  # and breaks its sandboxed `go install` of gopls/gofumpt/goimports. Drop
  # it here so `go install` falls back to GOPATH/bin.
  unset GOBIN
fi

if command -v starship &>/dev/null; then
  eval "$(starship init bash)"
fi

if command -v fzf &>/dev/null; then
  # bash 5.1+ supports `fzf --bash`; older fzf releases ship a separate script.
  if fzf --bash >/dev/null 2>&1; then
    eval "$(fzf --bash)"
  fi
fi

# ---------------------------------------------------------------------------
# Shared aliases (bash-compatible subset of dot_config/zsh/aliases.zsh)
# zsh-only function files under dot_config/zsh/functions/ are NOT sourced —
# they use zsh idioms (zsh-style read -q, ${@[-1]}) that won't run in bash.
# ---------------------------------------------------------------------------
if [[ -r "$HOME/.config/zsh/aliases.zsh" ]]; then
  source "$HOME/.config/zsh/aliases.zsh"
fi
