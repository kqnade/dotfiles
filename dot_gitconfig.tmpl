[user]
	name = kqnade
	email = git@k4na.de
	signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIPRS6ZG6P/46d8Ad9Q1mvaPbnQWFIv2F3MYdp3z2sNNj

{{ $isWsl := and (eq .chezmoi.os "linux") (contains "microsoft" (.chezmoi.kernel.osrelease | default "" | lower)) -}}

[gpg]
	format = ssh

[gpg "ssh"]
	allowedSignersFile = ~/.config/git/allowed_signers
{{- if eq .chezmoi.os "darwin" }}
	program = "/Applications/1Password.app/Contents/MacOS/op-ssh-sign"
{{- else if $isWsl }}
	program = "/mnt/c/Users/Yuzuki Kana/AppData/Local/Microsoft/WindowsApps/op-ssh-sign-wsl.exe"
{{- else if eq .chezmoi.os "linux" }}
	program = "/opt/1Password/op-ssh-sign"
{{- end }}

[ghq]
{{- if eq .chezmoi.os "windows" }}
	root = Z:/
{{- else }}
	root = ~/repos
{{- end }}

[alias]
	ci = commit
	co = checkout
	br = branch
	st = status
	last = log -1 HEAD
	sub = "submodule update --remote --merge"
	cc = "!zsh -c 'source ~/.config/zsh/functions/cc.zsh && git-cc'"
	ccc = "!zsh -c 'source ~/.config/zsh/functions/cc.zsh && git-ccc'"

[core]
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	enable = true
	navigate = true
	light = false

[merge]
	conflictstyle = zdiff3

[pull]
	ff = only
	rebase = true

[init]
	defaultBranch = main

[rebase]
	autoStash = true
	autoSquash = true

[commit]
	gpgSign = true

[tag]
	gpgSign = true

# `ghq get foo/bar` や bare な https clone を全部 SSH に rewrite。
# 1Password agent (ssh.exe shim 経由) で auth 抜けるので HTTPS の
# token 入力プロンプトが回避できる。
[url "git@github.com:"]
	insteadOf = https://github.com/

[url "git@gitlab.com:"]
	insteadOf = https://gitlab.com/

[credential "https://gitlab.com"]
	helper = !glab auth git-credential

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
