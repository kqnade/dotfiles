# PowerShell profile (managed by chezmoi)
# Path on Windows: $HOME\Documents\PowerShell\Microsoft.PowerShell_profile.ps1

# ---------------------------------------------------------------------------
# Environment
# ---------------------------------------------------------------------------
$env:LANG    = 'en_US.UTF-8'

# Editor preference: nvim > vim > notepad. Resolved at profile-load time so a
# late-loading PATH entry from `mise activate` is also considered.
$preferredEditor = if (Get-Command nvim -ErrorAction SilentlyContinue) { 'nvim' }
                   elseif (Get-Command vim -ErrorAction SilentlyContinue) { 'vim' }
                   else { 'notepad' }
$env:EDITOR = $preferredEditor
$env:VISUAL = $preferredEditor

[Console]::OutputEncoding = [System.Text.Encoding]::UTF8
$OutputEncoding           = [System.Text.Encoding]::UTF8

# Add user-local bin paths
$extraPaths = @(
    "$HOME\.local\bin",
    "$HOME\.bun\bin",
    "$HOME\scoop\shims"
) | Where-Object { Test-Path $_ }
foreach ($p in $extraPaths) {
    if (-not ($env:Path -split ';' -contains $p)) {
        $env:Path = "$p;$env:Path"
    }
}

# ---------------------------------------------------------------------------
# Tooling activation
# ---------------------------------------------------------------------------
if (Get-Command mise -ErrorAction SilentlyContinue) {
    mise activate pwsh | Out-String | Invoke-Expression
}

if (Get-Command starship -ErrorAction SilentlyContinue) {
    Invoke-Expression (& starship init powershell)
}

# ---------------------------------------------------------------------------
# PSReadLine — history & keybindings
# ---------------------------------------------------------------------------
if (Get-Module -ListAvailable PSReadLine) {
    Import-Module PSReadLine

    # CompletionPredictor feeds the "Plugin" half of HistoryAndPlugin. Without
    # any predictor module loaded, PSReadLine throws an NRE on every prompt.
    if (Get-Module -ListAvailable CompletionPredictor) {
        Import-Module CompletionPredictor
    }

    Set-PSReadLineOption -EditMode Emacs
    Set-PSReadLineOption -HistoryNoDuplicates
    Set-PSReadLineOption -HistorySearchCursorMovesToEnd
    if (Get-Module CompletionPredictor) {
        Set-PSReadLineOption -PredictionSource HistoryAndPlugin
    } else {
        Set-PSReadLineOption -PredictionSource History
    }
    Set-PSReadLineOption -PredictionViewStyle ListView

    Set-PSReadLineKeyHandler -Key UpArrow   -Function HistorySearchBackward
    Set-PSReadLineKeyHandler -Key DownArrow -Function HistorySearchForward
}

# ---------------------------------------------------------------------------
# Aliases
# ---------------------------------------------------------------------------
if (Get-Command eza -ErrorAction SilentlyContinue) {
    Remove-Item Alias:ls -Force -ErrorAction SilentlyContinue
    function ls { eza --icons --git @Args }
    function ll { eza -la --icons --git --group-directories-first @Args }
}

if (Get-Command bat -ErrorAction SilentlyContinue) {
    Set-Alias -Name cat -Value bat -Option AllScope
}

if ($preferredEditor -ne 'notepad') {
    Set-Alias -Name vi  -Value $preferredEditor -Option AllScope
    if ($preferredEditor -eq 'nvim') {
        Set-Alias -Name vim -Value $preferredEditor -Option AllScope
    }
}

# Package manager shortcut (scoop on Windows)
if (Get-Command scoop -ErrorAction SilentlyContinue) {
    Set-Alias -Name p -Value scoop -Option AllScope
}

# Simple aliases (parity with dot_config/zsh/aliases.zsh)
if (Get-Command git -ErrorAction SilentlyContinue) {
    Set-Alias -Name g -Value git -Option AllScope
}

if ($preferredEditor -ne 'notepad') {
    Set-Alias -Name v -Value $preferredEditor -Option AllScope
}

if (Get-Command chezmoi -ErrorAction SilentlyContinue) {
    function ca { chezmoi apply @Args }
    function ce { chezmoi edit @Args }
}

if (Get-Command claude -ErrorAction SilentlyContinue) {
    Set-Alias -Name cl -Value claude -Option AllScope
}

function path { $env:Path -split ';' }

# ---------------------------------------------------------------------------
# Functions (parity with dot_config/zsh/functions/)
# ---------------------------------------------------------------------------

# mkcd: create a directory and cd into it
function mkcd {
    param([Parameter(Mandatory)] [string] $Path)
    New-Item -ItemType Directory -Force -Path $Path | Out-Null
    Set-Location -Path $Path
}

# ccd: cd then clear
function ccd {
    param([Parameter(Mandatory)] [string] $Path)
    Set-Location -Path $Path
    Clear-Host
}

# gg: fzf-driven ghq repository switcher
function gg {
    param([string] $Query = '')

    if (-not (Get-Command ghq -ErrorAction SilentlyContinue)) {
        Write-Error 'ghq is not installed.'
        return
    }
    if (-not (Get-Command fzf -ErrorAction SilentlyContinue)) {
        Write-Error 'fzf is not installed.'
        return
    }

    $selected = ghq list | fzf --query="$Query" `
        --prompt='Repository > ' `
        --height=70% --reverse --border `
        --preview="powershell -NoProfile -Command `"`$repo = (ghq root) + '\' + '{}'; if (Test-Path (Join-Path `$repo '.git')) { git -C `$repo log --oneline -10 } else { Get-ChildItem `$repo }`"" `
        --preview-window=right:60%:wrap

    if (-not [string]::IsNullOrWhiteSpace($selected)) {
        $repoPath = Join-Path (ghq root) $selected
        Set-Location -Path $repoPath
        Write-Host "Moved to: $repoPath" -ForegroundColor Green
        if (Test-Path (Join-Path $repoPath '.git')) {
            $branch = git branch --show-current 2>$null
            Write-Host "Branch: $branch" -ForegroundColor Cyan
            git status -sb
        }
    }
}

# Auto-cd after `ghq get|clone|create`
function ghq {
    param(
        [Parameter(Position = 0)] [string] $Subcommand,
        [Parameter(ValueFromRemainingArguments = $true)] [string[]] $Rest
    )

    & (Get-Command ghq.exe -ErrorAction Stop).Source $Subcommand @Rest
    $code = $LASTEXITCODE

    if ($code -eq 0 -and ($Subcommand -in @('get', 'clone', 'create'))) {
        $target = $Rest[-1]
        if ($target) {
            $repoPath = & (Get-Command ghq.exe).Source list --full-path --exact $target 2>$null
            if ($repoPath) {
                Set-Location -Path $repoPath
                Write-Host "Moved to: $repoPath" -ForegroundColor Green
            }
        }
    }
    return $code
}

# git-ccc: AI-generated conventional commit (parity with dot_config/zsh/functions/ccc.zsh)
function git-ccc {
    if (-not (Get-Command git -ErrorAction SilentlyContinue)) {
        Write-Error 'git is not installed.'
        return
    }
    if (-not (Get-Command claude -ErrorAction SilentlyContinue)) {
        Write-Error 'claude CLI is not installed.'
        return
    }

    $diff = (git diff --staged) | Out-String
    if ([string]::IsNullOrWhiteSpace($diff)) {
        Write-Host "No staged changes. Run 'git add' first."
        return
    }

    $log = (git log --oneline -50) | Out-String

    Write-Host 'Generating commit message...'

    $prompt = @'
Generate a conventional commit message with a gitmoji prefix for the git diff below.
Use the recent commits as style reference to stay consistent.

Format: <emoji> <type>: <description>

Gitmoji mapping:
  feat     → ✨
  fix      → 🐛
  refactor → ♻️
  docs     → 📝
  test     → ✅
  chore    → 🔧
  perf     → ⚡️
  ci       → 👷
  style    → 🎨
  revert   → ⏪️
  build    → 📦

Rules:
- Output the commit message ONLY (no explanation, no markdown, no code block)
- Use imperative mood (e.g. 'add', 'fix', 'update')
- Keep it under 72 characters
'@

    $payload = "== Recent commits (for style reference) ==`n$log`n== Git diff ==`n$diff"
    $msg = ($payload | claude -p $prompt | Out-String).Trim()

    if ([string]::IsNullOrWhiteSpace($msg)) {
        Write-Error 'Failed to generate commit message.'
        return
    }

    Write-Host "Message: $msg"
    git commit -m $msg
}
