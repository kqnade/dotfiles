{{- if eq .chezmoi.os "linux" -}}
#!/usr/bin/env bash
# Linux bootstrap: delegates to scripts/install-linux.sh for distro-aware
# package installation. Branches by distro (sudo required on both):
#   - Arch    → metapkgs/base via makepkg
#   - Fedora  → dnf + Dnffile
#
# After OS packages are installed, also runs `mise bootstrap packages install` so
# [bootstrap.packages] entries (zsh, vim, openssh, build toolchain) are applied.
#
# Skipped in CI or any non-interactive context because the sudo prompt
# would block.
#
# Re-runs whenever any source manifest below changes. Brewfile is excluded
# because it's macOS-only.
# install-linux.sh: {{ include "scripts/install-linux.sh" | sha256sum }}
# Dnffile:          {{ include "Dnffile" | sha256sum }}
# PKGBUILD:         {{ include "metapkgs/base/PKGBUILD" | sha256sum }}

set -euo pipefail

if [[ "${CI:-}" == "true" ]] || [[ ! -t 0 ]]; then
  echo "==> Skipping Linux bootstrap (CI or non-interactive shell)" >&2
  exit 0
fi

REPO_ROOT="{{ .chezmoi.sourceDir }}"
bash "${REPO_ROOT}/scripts/install-linux.sh"

{{- if .features.mise_experimental }}
if [[ -x "$HOME/.local/bin/mise" ]]; then
  echo "==> Installing mise bootstrap packages..."
  "$HOME/.local/bin/mise" bootstrap packages install --yes
fi
{{- end }}
{{ end -}}
