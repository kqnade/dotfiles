# Fedora dnf packages (parallel to Brewfile and metapkgs/base/PKGBUILD).
# Consumed by scripts/install-linux.sh on the Fedora path.
# One package per line; '#' starts a comment.
#
# Scope: only OS-level bootstrap / font packages that mise system packages
# can't (or shouldn't) handle. The rest (zsh, vim, git, openssh, build
# toolchain) lives in dot_config/mise/config.toml [system.packages].

# Bootstrap tools (needed before mise itself can be installed)
curl
ca-certificates
unzip
fontconfig

# CJK fonts (UDEVGothic NF is fetched separately by run_onchange_after_install-fonts.sh)
google-noto-sans-cjk-fonts
google-noto-serif-cjk-fonts
