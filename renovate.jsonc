{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "helpers:pinGitHubActionDigestsToSemver"
  ],

  // 通常の機能追加・修正更新は、リリースから14日経過後にPR化する。
  "minimumReleaseAge": "14 days",

  // 脆弱性更新は待たずにPR化する。
  "vulnerabilityAlerts": {
    "enabled": true,
    "minimumReleaseAge": null
  },
  "osvVulnerabilityAlerts": true,

  "reviewersFromCodeOwners": true,

  "customManagers": [
    {
      "customType": "regex",
      "description": "Update npm-backed tools in the templated global mise config.",
      "managerFilePatterns": [
        "/(^|/)dot_config/mise/config\\.toml\\.tmpl$/"
      ],
      "matchStrings": [
        "\\\"npm:(?<depName>[^\\\"]+)\\\"\\s*=\\s*\\\"(?<currentValue>[^\\\"]+)\\\""
      ],
      "datasourceTemplate": "npm"
    },
    {
      "customType": "regex",
      "description": "Update Go-backed tools in the templated global mise config.",
      "managerFilePatterns": [
        "/(^|/)dot_config/mise/config\\.toml\\.tmpl$/"
      ],
      "matchStrings": [
        "\\\"go:(?<depName>[^\\\"]+)\\\"\\s*=\\s*\\\"(?<currentValue>[^\\\"]+)\\\""
      ],
      "datasourceTemplate": "go"
    },
    {
      "customType": "regex",
      "description": "Update GitHub-backed tools in the templated global mise config.",
      "managerFilePatterns": [
        "/(^|/)dot_config/mise/config\\.toml\\.tmpl$/"
      ],
      "matchStrings": [
        "\\\"github:(?<depName>[^\\\"]+)\\\"\\s*=\\s*\\\"(?<currentValue>[^\\\"]+)\\\"",
        "\\\"github:(?<depName>[^\\\"]+)\\\"\\s*=\\s*\\{\\s*version\\s*=\\s*\\\"(?<currentValue>[^\\\"]+)\\\""
      ],
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "description": "Update Aqua GitHub-backed tools in the templated global mise config.",
      "managerFilePatterns": [
        "/(^|/)dot_config/mise/config\\.toml\\.tmpl$/"
      ],
      "matchStrings": [
        "\\\"aqua:(?<depName>[^\\\"]+)\\\"\\s*=\\s*\\\"(?<currentValue>[^\\\"]+)\\\""
      ],
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "description": "Update npm packages invoked through bunx in Claude settings.",
      "managerFilePatterns": [
        "/(^|/)dot_claude/settings\\.json$/"
      ],
      "matchStrings": [
        "\\\"command\\\"\\s*:\\s*\\\"bunx -y (?<depName>(?:@[^/\\s@]+/)?[^@\\s]+)@(?<currentValue>[^\\s\\\"]+)"
      ],
      "datasourceTemplate": "npm"
    }
  ],

  "packageRules": [
    {
      "description": "Create security PRs immediately, bypassing the default 14-day release age.",
      "matchUpdateTypes": [
        "major",
        "minor",
        "patch",
        "pin",
        "digest"
      ],
      "matchJsonata": [
        "$exists(vulnerabilityFixVersion) or isVulnerabilityAlert"
      ],
      "minimumReleaseAge": null,
      "prCreation": "immediate"
    },
    {
      "description": "Prefer immutable Docker digest pins where Renovate supports them. Docker keeps the readable tag as image:1.2.3@sha256:...; GitHub Actions use helpers:pinGitHubActionDigestsToSemver for action@sha # v1.2.3.",
      "matchDatasources": [
        "docker"
      ],
      "pinDigests": true
    }
  ]
}
