#!/usr/bin/env bash
set -euo pipefail

# The installer creates authenticated HTTP entries named `mcp-agent-mail` for
# Claude and `mcp_agent_mail` for Codex. Remove the older stdio entries managed
# by this script: they cannot open the database while the HTTP service owns it.
missing=()
command -v claude >/dev/null 2>&1 || missing+=(claude)
command -v codex >/dev/null 2>&1 || missing+=(codex)
if ((${#missing[@]})); then
  echo "missing agent CLIs: ${missing[*]}; run chezmoi apply again after mise install" >&2
  exit 1
fi

# Product Bus groups related ghq repositories. Worktree shells set
# AGENT_MAIL_PROJECT to the canonical base repository in the launching shell.
service_changed=0
service_manager=""
case "$(uname -s)" in
  Darwin)
    service_manager="launchd"
    plist="$HOME/Library/LaunchAgents/com.agent-mail.plist"
    if [[ -f "$plist" ]]; then
      current=$(plutil -extract "EnvironmentVariables.WORKTREES_ENABLED" raw "$plist" 2>/dev/null || true)
      if [[ "$current" != "true" ]]; then
        plutil -replace "EnvironmentVariables.WORKTREES_ENABLED" -string true "$plist"
        service_changed=1
      fi
      for key in GIT_IDENTITY_ENABLED PROJECT_IDENTITY_MODE; do
        if plutil -extract "EnvironmentVariables.$key" raw "$plist" >/dev/null 2>&1; then
          plutil -remove "EnvironmentVariables.$key" "$plist"
          service_changed=1
        fi
      done
      if ! launchctl print "gui/$(id -u)/com.agent-mail" 2>/dev/null \
        | grep -q 'WORKTREES_ENABLED => true'; then
        service_changed=1
      fi
    fi
    ;;
  Linux)
    service_manager="systemd"
    dropin_dir="$HOME/.config/systemd/user/agent-mail.service.d"
    dropin="$dropin_dir/identity.conf"
    tmp=$(mktemp)
    trap 'rm -f "$tmp"' EXIT
    printf '%s\n' \
      '[Service]' \
      'Environment=WORKTREES_ENABLED=true' >"$tmp"
    if [[ ! -f "$dropin" ]] || ! cmp -s "$tmp" "$dropin"; then
      mkdir -p "$dropin_dir"
      install -m 600 "$tmp" "$dropin"
      systemctl --user daemon-reload
      service_changed=1
    fi
    ;;
esac

if ((service_changed)); then
  if [[ "$service_manager" == "launchd" ]]; then
    domain="gui/$(id -u)"
    launchctl bootout "$domain/com.agent-mail" 2>/dev/null || true
    launchctl bootstrap "$domain" "$plist"
  else
    am service restart >/dev/null
  fi
fi

claude mcp remove --scope user agent-mail >/dev/null 2>&1 || true
codex mcp remove agent-mail >/dev/null 2>&1 || true

for _ in {1..10}; do
  claude mcp get mcp-agent-mail >/dev/null 2>&1 && break
  sleep 1
done
if ! claude mcp get mcp-agent-mail >/dev/null 2>&1; then
  echo "Claude's mcp-agent-mail HTTP entry is missing or unhealthy; rerun chezmoi apply" >&2
  exit 1
fi
if ! codex mcp get mcp_agent_mail >/dev/null 2>&1; then
  echo "Codex's mcp_agent_mail HTTP entry is missing; rerun chezmoi apply" >&2
  exit 1
fi
