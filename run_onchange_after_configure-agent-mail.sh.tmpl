#!/usr/bin/env bash
set -euo pipefail

# Keep the CLIs' runtime-owned configs intact. Their commands update only the
# Agent Mail entry instead of replacing trusted-project and UI state.
missing=()
command -v claude >/dev/null 2>&1 || missing+=(claude)
command -v codex >/dev/null 2>&1 || missing+=(codex)
if ((${#missing[@]})); then
  echo "missing agent CLIs: ${missing[*]}; run chezmoi apply again after mise install" >&2
  exit 1
fi

claude mcp remove --scope user agent-mail >/dev/null 2>&1 || true
claude mcp add --scope user agent-mail -- mcp-agent-mail
codex mcp remove agent-mail >/dev/null 2>&1 || true
codex mcp add agent-mail -- mcp-agent-mail
