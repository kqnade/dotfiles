{{- if or (eq .chezmoi.os "darwin") (eq .chezmoi.os "linux") -}}
#!/usr/bin/env bash
# yaskkserv2 setup (cross-platform).
#
# Steps (idempotent):
#   1. Ensure the yaskkserv2 binaries are present:
#        - macOS:  delphinus/yaskkserv2 brew tap (HEAD build) — Brewfile.
#        - Linux:  cargo install from upstream when missing.
#   2. Rebuild merged dictionary when any SKK-JISYO.* source is newer than
#      ~/.skk/dictionary.yaskkserv2.
#   3. Install + (re)start the per-user service:
#        - macOS:  launchd agent under ~/Library/LaunchAgents
#        - Linux:  systemd user unit under ~/.config/systemd/user
#
# Re-runs when .chezmoiexternal.toml.tmpl (dictionary list) changes.
# .chezmoiexternal.toml.tmpl: {{ include ".chezmoiexternal.toml.tmpl" | sha256sum }}

set -euo pipefail

log()  { printf '\033[1;36m==>\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m!!\033[0m %s\n' "$*" >&2; }

SKK_DIR="$HOME/.skk"
DICT="$SKK_DIR/dictionary.yaskkserv2"
LISTEN_HOST="127.0.0.1"
LISTEN_PORT="1178"

{{- if eq .chezmoi.os "darwin" }}
GOOGLE_CACHE_DIR="$HOME/Library/Caches/yaskkserv2"
{{- else }}
GOOGLE_CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/yaskkserv2"
{{- end }}
GOOGLE_CACHE="$GOOGLE_CACHE_DIR/google.cache"
mkdir -p "$GOOGLE_CACHE_DIR"

# ---------------------------------------------------------------------------
# 1. Locate / install yaskkserv2 binaries
# ---------------------------------------------------------------------------
# Brew on macOS puts binaries in its own prefix; on non-sudo non-Debian Linux
# we get rust/cargo from pixi (~/.pixi/bin); on non-sudo Debian/Ubuntu from
# sideapt (~/.sideapt/usr/bin). cargo installs go to ~/.cargo/bin.
export PATH="$HOME/.cargo/bin:$HOME/.pixi/bin:$HOME/.local/bin:$PATH"
if [[ -x "$HOME/.local/bin/sideapt" ]]; then
  eval "$("$HOME/.local/bin/sideapt" env 2>/dev/null)" || true
  _sa_marc="$(dpkg-architecture -qDEB_HOST_MULTIARCH 2>/dev/null || true)"
  [[ -n "$_sa_marc" && -d "$HOME/.sideapt/usr/include/$_sa_marc" ]] \
    && export CPATH="$HOME/.sideapt/usr/include/$_sa_marc:${CPATH-}"
  [[ -n "$_sa_marc" && -d "$HOME/.sideapt/usr/lib/$_sa_marc" ]] \
    && export LIBRARY_PATH="$HOME/.sideapt/usr/lib/$_sa_marc:${LIBRARY_PATH-}"
  unset _sa_marc
fi
if [[ -x /opt/homebrew/bin/brew ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -x /usr/local/bin/brew ]]; then
  eval "$(/usr/local/bin/brew shellenv)"
fi

if ! command -v yaskkserv2 >/dev/null 2>&1 \
   || ! command -v yaskkserv2_make_dictionary >/dev/null 2>&1; then
{{- if eq .chezmoi.os "darwin" }}
  warn "yaskkserv2 binaries not found — expected from delphinus/yaskkserv2 tap."
  warn "Re-run \`brew bundle --file=$(chezmoi source-path)/Brewfile\` and try again."
  exit 0
{{- else }}
  if ! command -v cargo >/dev/null 2>&1; then
    warn "cargo not found in PATH; skipping yaskkserv2 setup"
    warn "(install via Aptfile/PKGBUILD/Brewfile then re-run \`chezmoi apply\`)"
    exit 0
  fi
  log "Installing yaskkserv2 via cargo (this may take a few minutes)..."
  cargo install --locked --git https://github.com/wachikun/yaskkserv2 --bins
{{- end }}
fi

YASKK_BIN="$(command -v yaskkserv2)"
MAKE_DICT_BIN="$(command -v yaskkserv2_make_dictionary)"

# ---------------------------------------------------------------------------
# 2. (Re)build dictionary
# ---------------------------------------------------------------------------
SOURCES=()
for d in L geo propernoun assoc JIS3_4 law; do
  src="$SKK_DIR/SKK-JISYO.$d"
  [[ -f "$src" ]] && SOURCES+=("$src")
done

if [[ ${#SOURCES[@]} -eq 0 ]]; then
  warn "No SKK-JISYO.* files in $SKK_DIR — chezmoi externals not yet fetched?"
  warn "Run \`chezmoi apply\` to populate them, then re-run this script."
  exit 0
fi

needs_rebuild=0
if [[ ! -f "$DICT" ]]; then
  needs_rebuild=1
else
  for s in "${SOURCES[@]}"; do
    if [[ "$s" -nt "$DICT" ]]; then
      needs_rebuild=1
      break
    fi
  done
fi

if [[ $needs_rebuild -eq 1 ]]; then
  log "Building yaskkserv2 dictionary from ${#SOURCES[@]} sources..."
  "$MAKE_DICT_BIN" --dictionary-filename="$DICT" "${SOURCES[@]}"
else
  log "yaskkserv2 dictionary is up to date."
fi

# ---------------------------------------------------------------------------
# 3. Service registration
# ---------------------------------------------------------------------------
# Common server flags (used by both launchd and systemd).
COMMON_ARGS=(
  --no-daemonize
  "--listen-address=$LISTEN_HOST"
  "--port=$LISTEN_PORT"
  --google-japanese-input=notfound
  "--google-cache-filename=$GOOGLE_CACHE"
)

{{- if eq .chezmoi.os "darwin" }}
PLIST="$HOME/Library/LaunchAgents/com.user.yaskkserv2.plist"
mkdir -p "$(dirname "$PLIST")" "$HOME/Library/Logs"

# Refined KeepAlive: restart on crash, but not when we tell it to stop.
cat > "$PLIST" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.user.yaskkserv2</string>
  <key>ProgramArguments</key>
  <array>
    <string>$YASKK_BIN</string>
$(printf '    <string>%s</string>\n' "${COMMON_ARGS[@]}")
    <string>$DICT</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <dict>
    <key>SuccessfulExit</key>
    <false/>
    <key>Crashed</key>
    <true/>
  </dict>
  <key>StandardOutPath</key>
  <string>$HOME/Library/Logs/yaskkserv2.log</string>
  <key>StandardErrorPath</key>
  <string>$HOME/Library/Logs/yaskkserv2.err</string>
</dict>
</plist>
EOF

DOMAIN="gui/$(id -u)"
launchctl bootout "$DOMAIN/com.user.yaskkserv2" >/dev/null 2>&1 || true
launchctl bootstrap "$DOMAIN" "$PLIST"
launchctl kickstart -k "$DOMAIN/com.user.yaskkserv2" >/dev/null 2>&1 || true
log "yaskkserv2 launchd agent loaded (port $LISTEN_PORT)."
{{- else }}
if command -v systemctl >/dev/null 2>&1 \
   && systemctl --user show-environment >/dev/null 2>&1; then
  UNIT_DIR="$HOME/.config/systemd/user"
  UNIT="$UNIT_DIR/yaskkserv2.service"
  mkdir -p "$UNIT_DIR"

  cat > "$UNIT" <<EOF
[Unit]
Description=yaskkserv2 — local SKK dictionary server
After=network.target

[Service]
ExecStart=$YASKK_BIN ${COMMON_ARGS[*]} $DICT
Restart=on-failure
RestartSec=2

[Install]
WantedBy=default.target
EOF

  systemctl --user daemon-reload
  systemctl --user enable --now yaskkserv2.service
  systemctl --user restart yaskkserv2.service
  log "yaskkserv2 systemd user unit enabled (port $LISTEN_PORT)."
else
  warn "systemd user session not available; start yaskkserv2 manually:"
  warn "  $YASKK_BIN ${COMMON_ARGS[*]} $DICT"
fi
{{- end }}
{{ end -}}
