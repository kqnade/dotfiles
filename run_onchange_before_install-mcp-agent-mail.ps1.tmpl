$ErrorActionPreference = "Stop"

# Update this value to intentionally upgrade MCP Agent Mail.
$version = "v0.3.21"
$installerUrl = "https://raw.githubusercontent.com/Dicklesworthstone/mcp_agent_mail_rust/$version/install.ps1"
$installer = Join-Path $env:TEMP "install-mcp-agent-mail-$PID.ps1"

try {
    Invoke-WebRequest -UseBasicParsing -Uri $installerUrl -OutFile $installer
    & $installer -Version $version -Dest (Join-Path $env:USERPROFILE ".local\bin") -Force
}
finally {
    Remove-Item -LiteralPath $installer -Force -ErrorAction SilentlyContinue
}
